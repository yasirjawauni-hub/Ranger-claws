local CRIT = false

local function showDamage(Char, Dealt, du, Color)
    local m = it("Model"); m.Name = tostring(Dealt)
    local h = it("Humanoid"); h.Health=0; h.MaxHealth=0; h.Parent=m
    local c = it("Part")
    c.Transparency = 0
    c.BrickColor   = Color
    c.Name         = "Head"
    c.TopSurface   = Enum.SurfaceType.Smooth
    c.BottomSurface= Enum.SurfaceType.Smooth
    c.Size         = vt(1,.4,1)
    c.CanCollide   = false
    local ms = it("CylinderMesh"); ms.Scale = vt(.8,.8,.8); ms.Parent=c
    if CRIT then ms.Scale = vt(1,1.25,1) end
    it("BodyGyro").Parent = c
    c.Parent = m
    local head = Char:FindFirstChild("Head") or (Char.Parent and Char.Parent:FindFirstChild("Head"))
    if head then c.CFrame = CFrame.new(head.CFrame.p + vt(0,1.5,0)) end
    local f = it("BodyPosition")
    f.P=2000; f.D=100
    f.maxForce = vt(math.huge,math.huge,math.huge)
    f.position = c.Position + vt(0,3,0)
    f.Parent = c
    Debris:AddItem(m, .5+du)
    c.CanCollide = false
    m.Parent = workspace
end

local function Damagefunc(hit, minim, maxim, knockback, Type, Property, Delay, KnockbackType)
    if not hit.Parent then return end
    local hum
    for _, v in pairs(hit.Parent:GetChildren()) do
        if v:IsA("Humanoid") then hum = v; break end
    end
    if hit.Parent.Parent and hit.Parent.Parent:FindFirstChild("Torso") then
        hum = hit.Parent.Parent:FindFirstChild("Humanoid")
    end
    if hit.Parent.ClassName == "Hat" then
        hit = hit.Parent.Parent:FindFirstChild("Head")
        if not hit then return end
    end
    if not hum then return end
    if hit.Parent.Name == Character.Name then return end
    if not hit.Parent:FindFirstChild("Torso") then return end
    if hit.Parent:FindFirstChild("DebounceHit") then
        if hit.Parent.DebounceHit.Value then return end
    end

    local creator = it("ObjectValue"); creator.Name="creator"
    creator.Value = Player; creator.Parent = hum
    Debris:AddItem(creator, .5)

    local Damage = math.random(minim, maxim)
    local blocked = false
    local block   = hit.Parent:FindFirstChild("Block")
    if block then
        if (block:IsA("NumberValue") or block:IsA("IntValue")) and block.Value > 0 then
            blocked = true; block.Value = block.Value - 1
        end
    end

    if not blocked then
        hum.Health = hum.Health - Damage
        showDamage(hit.Parent, Damage, .5, TorsoColor)
    else
        hum.Health = hum.Health - (Damage/2)
        showDamage(hit.Parent, math.floor(Damage/2), .5, BrickColor.new("Bright blue"))
    end

    if Type == "Knockdown" then
        hum.PlatformStand = true
        task.delay(1, function() hum.PlatformStand = false end)
        local bv = it("BodyVelocity")
        bv.velocity  = (hit.Position - Property.Position).unit * knockback
        bv.P         = 5000
        bv.maxForce  = vt(8e3,8e3,8e3)
        bv.Parent    = hit
        Debris:AddItem(bv, .5)
        local bav = it("BodyAngularVelocity")
        bav.P             = 3000
        bav.maxTorque     = vt(5e5,5e5,5e5)
        bav.angularvelocity = vt(math.random(-10,10),math.random(-10,10),math.random(-10,10))
        bav.Parent        = hit
        Debris:AddItem(bav, .5)
    elseif Type == "Normal" then
        local vp = it("BodyVelocity")
        vp.P = 500; vp.maxForce = vt(math.huge,0,math.huge)
        vp.velocity = (KnockbackType==1)
            and Property.CFrame.LookVector*knockback + Property.Velocity/1.05
            or  Property.CFrame.LookVector*knockback
        if knockback > 0 then vp.Parent = hit.Parent.Torso end
        Debris:AddItem(vp, .5)
    elseif Type == "Up" then
        local bv = it("BodyVelocity")
        bv.velocity = vt(0,10,0); bv.P=1000
        bv.maxForce = vt(1e9,1e9,1e9); bv.Parent=hit
        Debris:AddItem(bv, 1)
        local bav = it("BodyAngularVelocity")
        bav.P=3000; bav.maxTorque=vt(5e5,5e5,5e5)
        bav.angularvelocity=vt(math.random(-20,20),math.random(-20,20),math.random(-20,20))
        bav.Parent=hit; Debris:AddItem(bav,.5)
    elseif Type == "Snare" then
        local bp = it("BodyPosition")
        bp.P=2000; bp.D=100
        bp.maxForce=vt(math.huge,math.huge,math.huge)
        bp.position = hit.Parent.Torso.Position
        bp.Parent   = hit.Parent.Torso
        Debris:AddItem(bp,1)
    end

    local deb = it("BoolValue")
    deb.Name="DebounceHit"; deb.Parent=hit.Parent; deb.Value=true
    Debris:AddItem(deb, Delay)
    CRIT=false
end

