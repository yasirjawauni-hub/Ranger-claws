local function NoOutline(p)
    p.TopSurface    = Enum.SurfaceType.Smooth
    p.BottomSurface = Enum.SurfaceType.Smooth
    p.LeftSurface   = Enum.SurfaceType.Smooth
    p.RightSurface  = Enum.SurfaceType.Smooth
    p.FrontSurface  = Enum.SurfaceType.Smooth
    p.BackSurface   = Enum.SurfaceType.Smooth
end

local function part(parent, material, reflectance, transparency, brickcolor, name, size)
    local fp = it("Part")
    fp.Parent          = parent
    fp.Reflectance     = reflectance
    fp.Transparency    = transparency
    fp.CanCollide      = false
    fp.Locked          = true
    fp.BrickColor      = BrickColor.new(tostring(brickcolor))
    fp.Name            = name
    fp.Size            = size
    fp.Position        = Torso.Position
    fp.Material        = material
    NoOutline(fp)
    fp:BreakJoints()
    return fp
end

local function mesh(MeshClass, parent, meshtype, meshid, offset, scale)
    local m = it(MeshClass)
    m.Parent = parent
    if MeshClass == "SpecialMesh" then
        m.MeshType = meshtype
        if meshid and meshid ~= "" then
            m.MeshId = meshid
        end
    end
    m.Offset = offset
    m.Scale  = scale
    return m
end

local function weld(parent, part0, part1, c0, c1)
    local w = it("Weld")
    w.Parent = parent
    w.Part0  = part0
    w.Part1  = part1
    w.C0     = c0
    w.C1     = c1 or CFrame.new()
    return w
end

local function swait(num)
    if not num or num == 0 then
        RunService.Stepped:Wait(0)
    else
        for _ = 0, num do
            RunService.Stepped:Wait(0)
        end
    end
end

local function so(id, parent, vol, pit)
    local snd = it("Sound", parent or workspace)
    snd.Volume  = vol or 1
    snd.Pitch   = pit or 1
    snd.SoundId = id
    snd:Play()
    Debris:AddItem(snd, 6)
end

local function rayCast(Pos, Dir, Max, Ignore)
    return workspace:FindPartOnRay(Ray.new(Pos, Dir.unit * (Max or 999.999)), Ignore)
end

-- ================================================
-- QUATERNION CLERP
-- ================================================
local function QuaternionFromCFrame(c)
    local mx,my,mz,m00,m01,m02,m10,m11,m12,m20,m21,m22 = c:components()
    local trace = m00+m11+m22
    if trace > 0 then
        local s = math.sqrt(1+trace)
        local r = 0.5/s
        return (m21-m12)*r,(m02-m20)*r,(m10-m01)*r,s*0.5
    else
        local i = 0
        if m11>m00 then i=1 end
        if m22>(i==0 and m00 or m11) then i=2 end
        if i==0 then
            local s=math.sqrt(m00-m11-m22+1); local r=0.5/s
            return 0.5*s,(m10+m01)*r,(m20+m02)*r,(m21-m12)*r
        elseif i==1 then
            local s=math.sqrt(m11-m22-m00+1); local r=0.5/s
            return (m01+m10)*r,0.5*s,(m21+m12)*r,(m02-m20)*r
        else
            local s=math.sqrt(m22-m00-m11+1); local r=0.5/s
            return (m02+m20)*r,(m12+m21)*r,0.5*s,(m10-m01)*r
        end
    end
end

local function QuaternionToCFrame(px,py,pz,x,y,z,w)
    local xs,ys,zs = x+x,y+y,z+z
    local wx,wy,wz = w*xs,w*ys,w*zs
    local xx,xy,xz = x*xs,x*ys,x*zs
    local yy,yz,zz = y*ys,y*zs,z*zs
    return CFrame.new(px,py,pz,
        1-(yy+zz), xy-wz,   xz+wy,
        xy+wz,     1-(xx+zz),yz-wx,
        xz-wy,     yz+wx,   1-(xx+yy))
end

local function QuaternionSlerp(a,b,t)
    local cosTheta = a[1]*b[1]+a[2]*b[2]+a[3]*b[3]+a[4]*b[4]
    local s,f
    if cosTheta >= 0.0001 then
        if (1-cosTheta) > 0.0001 then
            local th = math.acos(cosTheta); local inv = 1/math.sin(th)
            s = math.sin((1-t)*th)*inv; f = math.sin(t*th)*inv
        else s=1-t; f=t end
    else
        if (1+cosTheta) > 0.0001 then
            local th = math.acos(-cosTheta); local inv = 1/math.sin(th)
            s = math.sin((t-1)*th)*inv; f = math.sin(t*th)*inv
        else s=t-1; f=t end
    end
    return a[1]*s+b[1]*f, a[2]*s+b[2]*f, a[3]*s+b[3]*f, a[4]*s+b[4]*f
end

local function clerp(a,b,t)
    local qa = {QuaternionFromCFrame(a)}
    local qb = {QuaternionFromCFrame(b)}
    local ax,ay,az = a.x,a.y,a.z
    local bx,by,bz = b.x,b.y,b.z
    local _t = 1-t
    return QuaternionToCFrame(
        _t*ax+t*bx, _t*ay+t*by, _t*az+t*bz,
        QuaternionSlerp(qa,qb,t))
end

