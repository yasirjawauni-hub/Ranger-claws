Mouse.Button1Down:Connect(function()
    if attack then return end
    if     attacktype==1 then attacktype=2; attackone()
    elseif attacktype==2 then attacktype=3; attacktwo()
    elseif attacktype==3 then attacktype=4; attackthree()
    elseif attacktype==4 then attacktype=1; attackfour()
    end
end)

UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    local k = input.KeyCode
    if k == Enum.KeyCode.E and not attack and mana>=20 then Push()
    elseif k == Enum.KeyCode.R and not attack and mana>=20 then Clap()
    elseif k == Enum.KeyCode.F and not attack and mana>=40 then Spin()
    elseif k == Enum.KeyCode.G and not attack and mana>=50 then Twirl()
    elseif k == Enum.KeyCode.V and not attack and mana>=25 then MagicJump()
    elseif k == Enum.KeyCode.Y and not attack and mana>=100 then Shred()
    elseif k == Enum.KeyCode.T and not attack then Hai()
    elseif k == Enum.KeyCode.Q and not attack then idle=1000
    elseif k == Enum.KeyCode.H and not attack then mana=100
    elseif k == Enum.KeyCode.Zero then Humanoid.WalkSpeed=56
    end
end)

