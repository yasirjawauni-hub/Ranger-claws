-- TRAIL HELPER
-- ================================================
local function spawnTrail(partRef)
    task.spawn(function()
        local old = partRef.CFrame.p
        while TrailDeb do
            RunService.Stepped:Wait(0)
            local new = partRef.CFrame.p
            local mag = (old-new).magnitude
            if mag > 0.01 then
                local mid = (old+new)/2
                local trail = it("Part",Character)
                trail.Material    = Enum.Material.Neon
                trail.Anchored    = true
                trail.CanCollide  = false
                trail.BrickColor  = TorsoColor
                trail.Size        = vt(0.2,mag,0.2)
                trail.TopSurface  = Enum.SurfaceType.Smooth
                trail.BottomSurface=Enum.SurfaceType.Smooth
                trail.CFrame      = CFrame.new(mid,new)*CFrame.Angles(math.pi/2,0,0)
                local tm = it("CylinderMesh",trail); tm.Scale=vt(1,1,1)
                task.spawn(function()
                    for i=1,0,-0.1 do swait(); tm.Scale=tm.Scale*vt(i,1,i) end
                    trail:Destroy()
                end)
                task.spawn(function()
                    for _=1,10 do swait(); trail.Transparency=trail.Transparency+0.1 end
                end)
            end
            old = new
        end
    end)
end

