    local pe = it("ParticleEmitter", parent)
    pe.VelocitySpread = 180
    pe.Lifetime       = NumberRange.new(0.1)
    pe.Speed          = NumberRange.new(2)
    pe.Size           = NumberSequence.new({NumberSequenceKeypoint.new(0,1), NumberSequenceKeypoint.new(1,sizeEnd)})
    pe.RotSpeed       = NumberRange.new(-45,45)
    pe.Rate           = 100
    pe.Rotation       = NumberRange.new(-45,45)
    pe.Transparency   = NumberSequence.new({NumberSequenceKeypoint.new(0,0), NumberSequenceKeypoint.new(0.701,0), NumberSequenceKeypoint.new(1,1)})
    pe.LightEmission  = lightEmit
    pe.Color          = ColorSequence.new(color, color)
    return pe
end

